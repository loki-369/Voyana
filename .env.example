# ============================================
# Voyana — Environment Variables
# ============================================

# 🔴 REQUIRED: PostgreSQL connection string (Neon recommended)
# Get a free database at: https://neon.tech
# After creating a project, paste the connection string below:
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# 🟡 OPTIONAL: OpenAI API Key for AI Assistant
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# 🟡 OPTIONAL: JWT Secret (use a random string in production)
JWT_SECRET="voyana-secret-jwt-key-2026"
